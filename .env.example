DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
FRONTEND_SITE_URL=http://localhost:5173

# OpenAI-compatible endpoint. Azure OpenAI v1-compatible endpoints work here.
OPENAI_BASE_URL=https://example.openai.azure.com/openai/v1/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
AI_DRAFTING_ENABLED=false

# Research is always constrained to a jurisdiction. This is the organization
# fallback; a Django-admin setting or individual user profile can override it.
DEFAULT_JURISDICTION=Ohio

# Repository content library. Keep the default for local development; a future
# admin-selected SharePoint provider will use the same logical layout.
CONTENT_LIBRARY_DIR=content

# LegalServer instance API settings. Paths are configurable because instances vary.
LEGALSERVER_BASE_URL=https://your-site.legalserver.org
LEGALSERVER_API_TOKEN=
LEGALSERVER_MATTERS_PATH=/api/v1/matters
LEGALSERVER_MATTER_DOCUMENTS_PATH=/api/v1/matters/{matter_id}/documents
LEGALSERVER_USER_FILTER_PARAM=assigned_user_email

# Microsoft Graph / SharePoint Online settings.
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_ACCESS_TOKEN=
SHAREPOINT_CASE_FOLDER_TEMPLATE=Cases/{matter_id}

# Office 365 sign-in and delegated Microsoft Graph access.
# Use "organizations" for any work/school Office 365 tenant, or a tenant ID for one tenant only.
OFFICE365_TENANT_ID=organizations
OFFICE365_CLIENT_ID=
OFFICE365_CLIENT_SECRET=
OFFICE365_REDIRECT_URI=http://localhost:5173/api/auth/office365/callback/
OFFICE365_SCOPES=openid profile email offline_access User.Read Sites.Read.All Files.Read.All

# Use Django RemoteUserMiddleware when Office 365 SSO is terminated upstream.
ENABLE_REMOTE_USER_AUTH=false
