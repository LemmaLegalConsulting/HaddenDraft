# Production deployment template.
# deploy/bootstrap-vm.sh renders /opt/haddendraft/.env from this file.
# Values written as {{KEY_VAULT_SECRET_NAME}} are fetched from Azure Key Vault.

DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=haddendraft.example.org
DJANGO_CSRF_TRUSTED_ORIGINS=https://haddendraft.example.org
DJANGO_CORS_ALLOWED_ORIGINS=https://haddendraft.example.org
FRONTEND_SITE_URL=https://haddendraft.example.org
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=31536000

DJANGO_SECRET_KEY={{DJANGO-SECRET-KEY}}
DATABASE_URL={{DATABASE-URL}}

OPENAI_BASE_URL=https://example.openai.azure.com/openai/v1/
OPENAI_API_KEY={{OPENAI-API-KEY}}
OPENAI_MODEL=gpt-5.4-mini
AI_DRAFTING_ENABLED=true

DEFAULT_JURISDICTION=Ohio
CONTENT_LIBRARY_DIR=content
DOCUMENT_TEXT_EXTRACTOR=stdlib

LEGALSERVER_BASE_URL=https://your-site.legalserver.org
LEGALSERVER_API_TOKEN={{LEGALSERVER-API-TOKEN}}
LEGALSERVER_MATTERS_PATH=/api/v2/matters
LEGALSERVER_MATTERS_RESULTS=full
LEGALSERVER_MATTER_DOCUMENTS_PATH=/api/v1/matters/{matter_id}/documents
LEGALSERVER_USER_FILTER_PARAM=assigned_user_email

SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_ACCESS_TOKEN={{SHAREPOINT-ACCESS-TOKEN}}
SHAREPOINT_CASE_FOLDER_TEMPLATE=Cases/{matter_id}

OFFICE365_TENANT_ID=organizations
OFFICE365_CLIENT_ID=
OFFICE365_CLIENT_SECRET={{OFFICE365-CLIENT-SECRET}}
OFFICE365_REDIRECT_URI=https://haddendraft.example.org/api/auth/office365/callback/
OFFICE365_SCOPES=openid profile email offline_access User.Read Sites.Read.All Files.Read.All

ENABLE_REMOTE_USER_AUTH=false
ENABLE_DEMO_MATTERS=false
